# ──────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────
# 로컬 개발: SQLite (기본)
DATABASE_URL="file:./dev.db"
# 프로덕션 (Vercel): Neon Postgres connection string으로 교체
# 예: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# ──────────────────────────────────────────────────
# Admin Authentication
# ──────────────────────────────────────────────────
# 강력한 비밀번호 사용 (배포 시 반드시 변경)
ADMIN_PASSWORD="change-me-please"
# 32자 이상 랜덤 문자열
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="change-me-to-a-random-string-at-least-32-characters-long"

# ──────────────────────────────────────────────────
# Email (Resend - https://resend.com)
# ──────────────────────────────────────────────────
# 가입 후 발급된 API 키
RESEND_API_KEY=""
# 발신자 (도메인 인증 완료 후에만 본 도메인 사용 가능)
EMAIL_FROM="B.Fashion ShowRoom <ksmin3874@fabiz.ktbizoffice.com>"
# 새 예약 접수 시 알림 받을 관리자 이메일
ADMIN_EMAIL="ksmin3874@fabiz.ktbizoffice.com"

# ──────────────────────────────────────────────────
# Site
# ──────────────────────────────────────────────────
SITE_NAME="B.Fashion ShowRoom"
# 배포 시 실제 도메인으로 변경 (예: https://bfashion.vercel.app)
SITE_URL="http://localhost:3000"

# ──────────────────────────────────────────────────
# Cron (배포 환경에서만 필요)
# ──────────────────────────────────────────────────
# Vercel Cron이 /api/cron/reminders 호출 시 인증에 사용
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET=""
